---
import "@/styles/global.css";
import { SUPPORTED_LANGUAGES, type Language } from "@/lib/i18n/config";

interface Props {
	title: string;
	description: string;
	keywords?: string;
	lang?: Language;
}

const { title, description, keywords: propKeywords, lang = "ja" } = Astro.props;
const siteUrl = "https://packbridge.manpuc.me";

// Handle canonical and alternate links
const pathname = Astro.url.pathname.replace(/\/$/, "");
const canonicalURL = new URL(pathname || "/", siteUrl);

const langPrefixes = SUPPORTED_LANGUAGES.filter((l) => l !== "ja").join("|");
const langRegex = new RegExp(`^/(${langPrefixes})`);
const currentPath = pathname.replace(langRegex, "");

const alternateLinks = SUPPORTED_LANGUAGES.map((l) => {
	const prefix = l === "ja" ? "" : `/${l}`;
	return {
		href: new URL(`${prefix}${currentPath}` || "/", siteUrl).href,
		lang: l === "tok" ? "tok" : l,
	};
});

// Locale mapping for OGP
const localeMap: Record<string, string> = {
	ja: "ja_JP",
	en: "en_US",
	ko: "ko_KR",
	zh: "zh_CN",
	tl: "tl_PH",
	tok: "mis_TOKI",
	es: "es_ES",
	fr: "fr_FR",
	de: "de_DE",
};

const keywords =
	propKeywords ||
	"Minecraft, Resource Pack, Texture Pack, Converter, Java to Bedrock, Bedrock to Java, PackBridge, マイクラ, リソースパック, 変換, 統合版";

const softwareAppStructuredData = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	name: "PackBridge",
	author: {
		"@type": "Person",
		name: "manpuc",
		url: "https://www.manpuc.me",
	},
	applicationCategory: "UtilitiesApplication",
	operatingSystem: "Windows, macOS, Linux, Android, iOS",
	description: description,
	url: siteUrl,
	screenshot: `${siteUrl}/og-image-ja.png`,
	offers: {
		"@type": "Offer",
		price: "0",
		priceCurrency: "JPY",
	},
	featureList: [
		"Java to Bedrock Conversion",
		"Bedrock to Java Conversion",
		"Local Processing",
		"Fast Conversion",
		"No File Size Limit",
	],
};

const faqStructuredData = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: [
		{
			"@type": "Question",
			name:
				lang === "ja"
					? "ファイルはサーバーにアップロードされますか？"
					: "Are files uploaded to a server?",
			acceptedAnswer: {
				"@type": "Answer",
				text:
					lang === "ja"
						? "いいえ、すべての変換処理はブラウザ内（ローカル）で完結します。ファイルが外部に送信されることはありません。"
						: "No, all conversion processes are completed within your browser (locally). Files are never sent to external servers.",
			},
		},
		{
			"@type": "Question",
			name:
				lang === "ja"
					? "どのエディションに対応していますか？"
					: "Which editions are supported?",
			acceptedAnswer: {
				"@type": "Answer",
				text:
					lang === "ja"
						? "Java Edition と Bedrock Edition（統合版）の相互変換に対応しています。"
						: "It supports bidirectional conversion between Java Edition and Bedrock Edition.",
			},
		},
	],
};

const breadcrumbStructuredData = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: "Home",
			item: siteUrl,
		},
		...(lang !== "ja"
			? [
					{
						"@type": "ListItem",
						position: 2,
						name: lang.toUpperCase(),
						item: `${siteUrl}/${lang}`,
					},
				]
			: []),
		...(pathname.includes("/terms")
			? [
					{
						"@type": "ListItem",
						position: lang !== "ja" ? 3 : 2,
						name: "Terms",
						item: `${siteUrl}${lang === "ja" ? "" : "/" + lang}/terms`,
					},
				]
			: []),
	],
};

const webSiteStructuredData = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "PackBridge",
	url: siteUrl,
	description: description,
	inLanguage: SUPPORTED_LANGUAGES,
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- SEO -->
		<link rel="canonical" href={canonicalURL} />
		{
			alternateLinks.map(({ href, lang }) => (
				<link rel="alternate" hreflang={lang} href={href} />
			))
		}
		<link
			rel="alternate"
			hreflang="x-default"
			href={new URL(currentPath || "/", siteUrl).href}
		/>

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="manpuc" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<meta name="content-language" content={lang} />
		<meta
			name="theme-color"
			content="#f2f2f7"
			media="(prefers-color-scheme: light)"
		/>
		<meta
			name="theme-color"
			content="#000000"
			media="(prefers-color-scheme: dark)"
		/>

		<!-- Icons -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			rel="icon"
			type="image/png"
			sizes="144x144"
			href="/favicon-144.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="192x192"
			href="/favicon-192.png"
		/>
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="generator" content={Astro.generator} />

		<!-- OGP -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content={localeMap[lang] || "ja_JP"} />
		<meta property="og:site_name" content="PackBridge" />
		<meta property="og:image" content={`${siteUrl}/og-image-${lang}.png`} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@manpuc" />

		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
				rel="stylesheet"
			/>
		</noscript>

		<!-- Structured Data -->
		<script
			type="application/ld+json"
			set:html={JSON.stringify([
				softwareAppStructuredData,
				breadcrumbStructuredData,
				webSiteStructuredData,
				faqStructuredData,
			])}
		/>
		<!-- Cloudflare Web Analytics -->
		<script
			is:inline
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon='{"token": "6b934b828287452bae52d2ea1befff6b"}'
		></script>
		<!-- End Cloudflare Web Analytics -->
	</head>
	<body>
		<slot />
	</body>
</html>

<script is:inline>
	// Theme handling
	const getTheme = () => {
		if (
			typeof localStorage !== "undefined" &&
			localStorage.getItem("theme")
		) {
			return localStorage.getItem("theme");
		}
		return window.matchMedia("(prefers-color-scheme: dark)").matches
			? "dark"
			: "light";
	};
	document.documentElement.setAttribute("data-theme", getTheme());

	// Initial Redirect handling (Root only)
	if (location.pathname === "/") {
		const savedLang = localStorage.getItem("lang");
		if (savedLang && savedLang !== "ja") {
			location.href = "/" + savedLang;
		}
	}

	// Footer Logo Touch Handling
	document.addEventListener("click", (e) => {
		const footerInfo = e.target.closest(".footer-info");
		if (footerInfo && window.matchMedia("(pointer: coarse)").matches) {
			if (!footerInfo.classList.contains("touch-active")) {
				e.preventDefault();
				footerInfo.classList.add("touch-active");
			}
		} else {
			const activeFooter = document.querySelector(
				".footer-info.touch-active",
			);
			if (activeFooter && (!footerInfo || activeFooter !== footerInfo)) {
				activeFooter.classList.remove("touch-active");
			}
		}
	});
</script>
