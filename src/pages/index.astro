---
import Layout from "@/layouts/Layout.astro";
import ThemeToggle from "@/components/ThemeToggle";
import LangToggle from "@/components/LangToggle";
import Converter from "@/components/Converter";
import { getTranslation } from "@/lib/i18n";

const lang = "ja";
const t = getTranslation(lang);
---

<Layout title={t.title} description={t.description} keywords={t.keywords} lang="ja">
	<div class="top-controls">
		<LangToggle client:load />
		<ThemeToggle client:load />
	</div>

	<main class="container">
		<header>
			<h1>{t.heading}</h1>
			<p class="description">{t.description}</p>
		</header>

		<Converter client:load t={t} lang={lang} />

		<footer>
			<div class="footer-main">
				<div class="footer-credit">
					{t.footer}
				</div>

				<div class="footer-links">
					<a href="/terms" class="footer-link">{t.terms}</a>
				</div>
			</div>

			<a
				href="https://www.manpuc.me"
				target="_blank"
				rel="noopener noreferrer"
				class="footer-info"
			>
				<img
					src="https://www.manpuc.me/favicon.svg"
					alt="manpuc logo"
					class="footer-logo"
					width="24"
					height="24"
					loading="lazy"
				/>
				<span class="developed-by">Developed by manpuc</span>
			</a>
		</footer>
	</main>
</Layout>
