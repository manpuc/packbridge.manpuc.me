---
import Layout from "@/layouts/Layout.astro";
import ThemeToggle from "@/components/ThemeToggle";
import LangToggle from "@/components/LangToggle";
import { getTranslation } from "@/lib/i18n";

const lang = "ja";
const t = getTranslation(lang);
---

<Layout title={`${t.terms} - PackBridge`} description={t.description} keywords={t.keywords} lang={lang}>
	<div class="top-controls">
		<LangToggle client:load />
		<ThemeToggle client:load />
	</div>

	<main class="container">
		<header>
			<h1>{t.terms}</h1>
			<p class="description">最終更新: {t.termsLastUpdated}</p>
		</header>

		<div class="terms-grid">
			{
				t.termsSections.map((item) => (
					<section class="card terms-section">
						<h2>{item.title}</h2>
						<p>{item.content}</p>
					</section>
				))
			}
		</div>

		<footer class="terms-footer">
			<p class="os-text">
				{t.openSourceText}
			</p>
			<div class="footer-buttons">
				<a href="https://github.com/manpuc/packbridge.manpuc.me" target="_blank" rel="noopener noreferrer" class="footer-link source-link">
					{t.viewSourceCode}
				</a>
				<a href="/" class="footer-link">
					{t.backToHome}
				</a>
			</div>
		</footer>
	</main>
</Layout>

<style>
	.terms-footer {
		margin-top: 60px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 20px;
		padding-top: 40px;
		border-top: 1px solid var(--color-border);
	}

	.os-text {
		font-size: 13px;
		color: var(--color-text-muted);
		text-align: center;
	}

	.footer-buttons {
		display: flex;
		flex-direction: row;
		justify-content: center;
		gap: 24px;
		flex-wrap: wrap;
	}

	.footer-buttons .footer-link {
		font-weight: 600;
		color: var(--color-text);
	}

	.terms-grid {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.terms-section h2 {
		font-size: 18px;
		font-weight: 700;
		margin-bottom: 12px;
		color: var(--color-text);
	}

	.terms-section p {
		font-size: 15px;
		line-height: 1.6;
		color: var(--color-text-muted);
		white-space: pre-wrap;
	}

	header .description {
		margin-top: 8px;
		font-size: 14px;
	}

	footer {
		margin-top: 40px;
	}
</style>
